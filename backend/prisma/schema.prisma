// This is your Prisma schema file.
// Reflects the full Your Study Companion database schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String    @unique @db.Uuid
  email          String
  email_username String
  matric_number  String?   @unique
  phone_number   String?
  full_name      String?
  avatar_url     String?
  student_id     String    @unique
  field_of_study String?
  account_status String    @default("active")
  deactivated_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  user_stats     UserStats?

  @@map("profiles")
}

model StudentPdf {
  id          String           @id @default(uuid()) @db.Uuid
  user_id     String           @db.Uuid
  file_name   String
  file_path   String
  file_size   BigInt?
  uploaded_at DateTime         @default(now())

  course_materials CourseMaterial[]

  @@map("student_pdfs")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String?  @db.Uuid
  content     String
  created_at  DateTime @default(now())

  @@map("chat_messages")
}

model AiConversation {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  role       String   // 'user' | 'assistant'
  content    String
  created_at DateTime @default(now())

  @@map("ai_conversations")
}

model SchoolNews {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  content      String
  category     String?  @default("General")
  published_at DateTime @default(now())
  created_at   DateTime @default(now())

  @@map("school_news")
}

model LearningActivity {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String   @db.Uuid
  activity_type  String   // 'ai_chat' | 'pdf_upload' | 'quiz' | 'flashcard' | 'research' | 'study_plan' | 'gpa_calc' | 'study_tip' | 'course_material' | 'test_session'
  activity_count Int      @default(1)
  activity_date  DateTime @default(now()) @db.Date
  created_at     DateTime @default(now())

  @@map("learning_activity")
}

model GpaRecord {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  semester      String?
  courses       Json
  gpa           Decimal  @db.Decimal(3, 2)
  total_credits Int
  gpa_class     String?
  created_at    DateTime @default(now())

  @@map("gpa_records")
}

model StudyPlan {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String
  subjects    Json
  total_hours Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("study_plans")
}

model CourseMaterial {
  id             String      @id @default(uuid()) @db.Uuid
  user_id        String      @db.Uuid
  pdf_id         String?     @db.Uuid
  title          String
  description    String?
  parsed_content String?
  study_tools    Json?
  is_processed   Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  pdf StudentPdf? @relation(fields: [pdf_id], references: [id], onDelete: Cascade)

  @@map("course_materials")
}

model ResearchHistory {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  query      String
  results    Json?
  ai_summary String?
  created_at DateTime @default(now())

  @@map("research_history")
}

model UserStats {
  id                        String    @id @default(uuid()) @db.Uuid
  user_id                   String    @unique @db.Uuid
  total_study_minutes       Int       @default(0)
  total_ai_interactions     Int       @default(0)
  total_pdfs_processed      Int       @default(0)
  total_quizzes_completed   Int       @default(0)
  total_flashcards_reviewed Int       @default(0)
  total_research_minutes    Int       @default(0)
  total_study_tips_viewed   Int       @default(0)
  total_plans_created       Int       @default(0)
  current_streak            Int       @default(0)
  longest_streak            Int       @default(0)
  last_activity_date        DateTime? @db.Date
  last_pulse_at             DateTime? @default(now())
  xp_points                 Int       @default(0)
  level                     Int       @default(1)
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  profile Profile @relation(fields: [user_id], references: [user_id])

  @@map("user_stats")
}

model BillingPlan {
  id                 String   @id @default(uuid()) @db.Uuid
  slug               String   @unique
  name               String
  description        String?
  billing_interval   String
  price_kobo         Int      @default(0)
  currency           String   @default("NGN")
  ai_token_limit     Int?
  provider_limits    Json?
  paystack_plan_code String?
  is_active          Boolean  @default(true)
  is_custom          Boolean  @default(false)
  sort_order         Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]

  @@map("plans")
}

model Subscription {
  id                         String    @id @default(uuid()) @db.Uuid
  user_id                    String    @db.Uuid
  plan_id                    String    @db.Uuid
  status                     String    @default("trial")
  current_period_start       DateTime?
  current_period_end         DateTime?
  trial_ends_at              DateTime?
  paystack_subscription_code String?   @unique
  paystack_email_token       String?
  cancel_at_period_end       Boolean   @default(false)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  plan     BillingPlan @relation(fields: [plan_id], references: [id])
  payments Payment[]
  invoices Invoice[]

  @@index([user_id])
  @@map("subscriptions")
}

model Payment {
  id                      String    @id @default(uuid()) @db.Uuid
  user_id                 String    @db.Uuid
  subscription_id         String?   @db.Uuid
  plan_id                 String?   @db.Uuid
  status                  String
  amount_kobo             Int
  currency                String    @default("NGN")
  provider                String    @default("paystack")
  provider_reference      String    @unique
  provider_transaction_id String?
  channel                 String?
  paid_at                 DateTime?
  raw                     Json?
  created_at              DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscription_id], references: [id])
  plan         BillingPlan?  @relation(fields: [plan_id], references: [id])

  @@index([user_id])
  @@map("payments")
}

model Invoice {
  id                    String    @id @default(uuid()) @db.Uuid
  user_id               String    @db.Uuid
  subscription_id       String?   @db.Uuid
  status                String
  amount_kobo           Int
  currency              String    @default("NGN")
  provider_invoice_code String?   @unique
  due_at                DateTime?
  paid_at               DateTime?
  raw                   Json?
  created_at            DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscription_id], references: [id])

  @@index([user_id])
  @@map("invoices")
}

model PaymentEvent {
  id                String   @id @default(uuid()) @db.Uuid
  provider          String   @default("paystack")
  event_type        String
  provider_event_id String?  @unique
  raw               Json
  created_at        DateTime @default(now())

  @@map("payment_events")
}

model AiUsageEvent {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @db.Uuid
  provider          String
  feature           String
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  metadata          Json?
  created_at        DateTime @default(now())

  @@index([user_id, created_at])
  @@map("ai_usage_events")
}

// ------------------------------------------------------
// IGNORED SUPABASE TABLES
// These tables exist in the database and have policies attached to them.
// We use @@ignore so Prisma doesn't try to drop them during `db push`.
// ------------------------------------------------------

model rooms {
  id String @id @default(uuid()) @db.Uuid
  @@ignore
}

model room_members {
  id String @id @default(uuid()) @db.Uuid
  @@ignore
}
