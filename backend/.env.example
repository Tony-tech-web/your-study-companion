# PostgreSQL connection string (Supabase direct connection)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase project credentials (for JWT verification)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Server config
PORT=3000
NODE_ENV=development

# CORS - frontend origin
CLIENT_URL="http://localhost:5173"

# Admin console credentials
# Required in production. Local development falls back to admin / orbit-admin.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-admin-password"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
