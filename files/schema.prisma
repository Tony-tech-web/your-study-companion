// This is your Prisma schema file.
// Reflects the full Your Study Companion database schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String    @id @default(uuid())
  user_id        String    @unique
  email          String
  email_username String
  matric_number  String?   @unique
  phone_number   String?
  full_name      String?
  avatar_url     String?
  student_id     String    @unique
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("profiles")
}

model StudentPdf {
  id          String           @id @default(uuid())
  user_id     String
  file_name   String
  file_path   String
  file_size   BigInt?
  uploaded_at DateTime         @default(now())

  course_materials CourseMaterial[]

  @@map("student_pdfs")
}

model ChatMessage {
  id          String   @id @default(uuid())
  sender_id   String
  receiver_id String?
  content     String
  created_at  DateTime @default(now())

  @@map("chat_messages")
}

model AiConversation {
  id         String   @id @default(uuid())
  user_id    String
  role       String   // 'user' | 'assistant'
  content    String
  created_at DateTime @default(now())

  @@map("ai_conversations")
}

model SchoolNews {
  id           String   @id @default(uuid())
  title        String
  content      String
  category     String?  @default("General")
  published_at DateTime @default(now())
  created_at   DateTime @default(now())

  @@map("school_news")
}

model LearningActivity {
  id             String   @id @default(uuid())
  user_id        String
  activity_type  String   // 'ai_chat' | 'pdf_upload' | 'quiz' | 'flashcard' | 'research' | 'study_plan' | 'gpa_calc'
  activity_count Int      @default(1)
  activity_date  DateTime @default(now()) @db.Date
  created_at     DateTime @default(now())

  @@map("learning_activity")
}

model GpaRecord {
  id            String   @id @default(uuid())
  user_id       String
  semester      String?
  courses       Json
  gpa           Decimal  @db.Decimal(3, 2)
  total_credits Int
  gpa_class     String?
  created_at    DateTime @default(now())

  @@map("gpa_records")
}

model StudyPlan {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  subjects    Json
  total_hours Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("study_plans")
}

model CourseMaterial {
  id             String      @id @default(uuid())
  user_id        String
  pdf_id         String?
  title          String
  description    String?
  parsed_content String?
  study_tools    Json?
  is_processed   Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  pdf StudentPdf? @relation(fields: [pdf_id], references: [id], onDelete: Cascade)

  @@map("course_materials")
}

model ResearchHistory {
  id         String   @id @default(uuid())
  user_id    String
  query      String
  results    Json?
  ai_summary String?
  created_at DateTime @default(now())

  @@map("research_history")
}

model UserStats {
  id                        String    @id @default(uuid())
  user_id                   String    @unique
  total_study_minutes       Int       @default(0)
  total_ai_interactions     Int       @default(0)
  total_pdfs_processed      Int       @default(0)
  total_quizzes_completed   Int       @default(0)
  total_flashcards_reviewed Int       @default(0)
  current_streak            Int       @default(0)
  longest_streak            Int       @default(0)
  last_activity_date        DateTime? @db.Date
  xp_points                 Int       @default(0)
  level                     Int       @default(1)
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  @@map("user_stats")
}
