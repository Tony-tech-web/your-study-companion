# PostgreSQL connection string (your standalone DB)
DATABASE_URL="postgresql://user:password@host:5432/your_study_companion"

# Supabase project credentials (for JWT verification + Storage + Edge Functions)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Server config
PORT=3000
NODE_ENV=development

# CORS - frontend origin
CLIENT_URL="http://localhost:5173"
